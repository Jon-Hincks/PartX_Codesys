{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)d205ef02-8e2e-4fa5-992b-01b421f45225","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)CalculateWRF","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)True","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}},{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)93c25127-7679-4878-874e-6779ebbc29ea"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","bool":"System.Boolean","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)//\tFollowing the method available on Mecademic website : \n//\thttps://support.mecademic.com/en/support/solutions/articles/64000248048-how-do-i-calculate-the-wrf-using-a-3-point-method-\n\n\t  //[0]= x //[1]=y //[2]=z\n       ux[0]:=(P2[0]-P1[0]); \n\t   ux[1]:=(P2[1]-P1[1]); \n\t   ux[2]:=(P2[2]-P1[2]); \n\t\n\t   Norm_ux:=SQRT((ux[0]*ux[0])+(ux[1]*ux[1])+(ux[2]*ux[2]));\n\t   \n\tIF Norm_ux>10 THEN \n\t   uvx[0]:=ux[0]/Norm_ux;\n\t   uvx[1]:=ux[1]/Norm_ux;\n\t   uvx[2]:=ux[2]/Norm_ux;\n\tEND_IF\n\t\n\t   v13[0]:=(P3[0]-P1[0]);\n\t   v13[1]:=(P3[1]-P1[1]);\n\t   v13[2]:=(P3[2]-P1[2]);\n\t\n\t   Norm_v13:=SQRT((v13[0]*v13[0])+(v13[1]*v13[1])+(v13[2]*v13[2]));\n\t   \n\tIF Norm_v13> 10 THEN  \n\t   uv13[0]:=v13[0]/norm_v13;\n\t   uv13[1]:=v13[1]/norm_v13;\n\t   uv13[2]:=v13[2]/norm_v13;\n\tEND_IF\n\t\n\t   uz[0]:=(uvx[1]*uv13[2])-(uvx[2]*uv13[1]); \n\t   uz[1]:=(uvx[2]*uv13[0])-(uvx[0]*uv13[2]); \n\t   uz[2]:=(uvx[0]*uv13[1])-(uvx[1]*uv13[0]); \n\t\n\tIF NOT(Norm_ux<10)AND NOT(norm_v13 <10)THEN\n\t   Norm_uz:=SQRT((uz[0]*uz[0])+(uz[1]*uz[1])+(uz[2]*uz[2]));\n\t   uvz[0]:=uz[0]/norm_uz; \n\t   uvz[1]:=uz[1]/norm_uz; \n\t   uvz[2]:=uz[2]/norm_uz; \n\tEND_IF\n\t\n\t   uvy[0]:=(uvz[1]*uvx[2])-(uvz[2]*uvx[1]);\n\t   uvy[1]:=(uvz[2]*uvx[0])-(uvz[0]*uvx[2]); \n\t   uvy[2]:=(uvz[0]*uvx[1])-(uvz[1]*uvx[0]); \n\t\n\tIF ABS (uvz[0])=1 THEN\n\t\t\tBeta_deg:=uvz[0]*90;\n\t\t\tGamma:= MATH.atan2(lrSinus:= uvY[0], lrCosinus:=uvX[0] );\n\t\t\t\n\t\t    Gamma_Lreal_to_REAL:=LREAL_TO_REAL(Gamma);\n\t\t\tGamma_deg:=TES.FC_RadToDeg(i_rRad:=Gamma_Lreal_to_REAL );  \n\t\t\tAlpha_deg:=0;\n\tELSE\n\t\t\tBeta:=ASIN(uvz[0]);\n\t\t\tBeta_deg:=TES.FC_RadToDeg(i_rRad:=Beta );\n\t\t\tGamma:= MATH.atan2(lrSinus:= -uvy[0], lrCosinus:= uvx[0]);\n\t\t\tGamma_Lreal_to_REAL:=LREAL_TO_REAL(Gamma);\n\t\t\tGamma_deg:=TES.FC_RadToDeg(i_rRad:=Gamma_Lreal_to_REAL ); \n\t\t\tAlpha:= MATH.atan2(lrSinus:=-uvz[1] , lrCosinus:=uvz[2]);\n\t\t\tAlpha_Lreal_to_REAL:=LREAL_TO_REAL(Alpha);\n\t\t\tAlpha_deg:=TES.FC_RadToDeg(i_rRad:=Alpha_Lreal_to_REAL );\n\tEND_IF\n\t\n\t\t\tResult_WRF[0]:=P1[0];      // x    \n\t\t\tResult_WRF[1]:=P1[1];      // y\n\t\t\tResult_WRF[2]:=P1[2];      // z\n\t\t\tResult_WRF[3]:=alpha_deg;  // α\n\t\t\tResult_WRF[4]:=beta_deg;   // β\n\t\t\tResult_WRF[5]:=gamma_deg;  // γ\n\t","LineInfoPersistence":"(string)d205ef02-8e2e-4fa5-992b-01b421f45225_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK CalculateWRF\nVAR\n\tNorm_uz: REAL;\n\t// Direction du vecteur\n\tNorm_ux: REAL := 1;\n\tux: ARRAY[0..2] OF REAL;\n\t// Vecteur x selon ux\n\tuvx: ARRAY[0..2] OF REAL;\n\t// Vecteur y selon ux\n\tuvy: ARRAY[0..2] OF REAL;\n\tuz: ARRAY[0..2] OF REAL;\n\tGamma_Lreal_to_REAL: REAL;\n\tAlpha_Lreal_to_REAL: REAL;\nEND_VAR\nVAR_INPUT\n\t// Point n°1\n\tP1: ARRAY[0..2] OF REAL;\n\t// Point n°2\n\tP2: ARRAY[0..2] OF REAL;\n\t// Point n°3\n\tP3: ARRAY[0..2] OF REAL;\nEND_VAR\nVAR\n\t//  α\n\tAlpha: LREAL;\n\tv13: ARRAY[0..2] OF REAL;\n\t// Angle α en degré\n\tAlpha_deg: REAL;\n\t// β\n\tBeta: REAL;\n\t// Angle β en degré\n\tBeta_deg: REAL;\n\t// γ\n\tGamma: LREAL;\n\t// Angle γ en degré\n\tGamma_deg: REAL;\nEND_VAR\nVAR_OUTPUT\n\t// Coordonné WRF\n\tResult_WRF: ARRAY[0..5] OF REAL;\nEND_VAR\nVAR\n\tNorm_v13: REAL;\n\tuv13: ARRAY[0..2] OF REAL;\n\tuvz: ARRAY[0..2] OF REAL;\nEND_VAR\n","LineInfoPersistence":"(string)d205ef02-8e2e-4fa5-992b-01b421f45225_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)2802","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}