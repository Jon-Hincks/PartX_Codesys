{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)333b9f64-ae1a-4255-b850-ebc17895e63a","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)SetConf","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)f123d6c0-2583-4434-ac61-4a7aafb83d96"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)        (*Collect Inputs and store them locally*)\nOutput_Params[1]:=Shoulder;\nOutput_Params[2]:=Elbow;\nOutput_Params[3]:=Wrist;\nOutput_Params[4]:=0;\nOutput_Params[5]:=0;\nOutput_Params[6]:=0;\n\n\n(* If Values have change, Reinitialise Outputs*)\n\nIF FirstScan=0 OR Robot.Outputs.MotionCommand.Argument0 <> Output_Params[1] OR Robot.Outputs.MotionCommand.Argument1 <> Output_Params[2] OR Robot.Outputs.MotionCommand.Argument2 <> Output_Params[3] OR Robot.Outputs.MotionCommand.Argument3 <> Output_Params[4] OR Robot.Outputs.MotionCommand.Argument4 <> Output_Params[5] OR Robot.Outputs.MotionCommand.Argument5 <> Output_Params[6] THEN\n\tBuffered := FALSE;\n\tSent := FALSE;\nEND_IF;\n\n\n(*if not in legacy mode, Act Setpoint*)\nIF Robot.Outputs.MoveID <> 0 THEN\n    Robot.Outputs.MotionControl.SetPoint := TRUE;\nEND_IF;\n\n(* To send _Move, send _Move ID *)\nIF NOT Buffered AND NOT Sent THEN\n    \n    Robot.Outputs.MotionCommand.MoveCommand := Meca500_MotionCommandID.SET_CONF;\n    Robot.Outputs.MotionCommand.Argument0 := Output_Params[1];\n\tRobot.Outputs.MotionCommand.Argument1 := Output_Params[2];\n\tRobot.Outputs.MotionCommand.Argument2 := Output_Params[3];\n\tRobot.Outputs.MotionCommand.Argument3 := Output_Params[4];\n\tRobot.Outputs.MotionCommand.Argument4 := Output_Params[5];\n\tRobot.Outputs.MotionCommand.Argument5 := Output_Params[6];\n    \n    IF ExternalStateControl THEN\n        IF ExternalMoveID <> 0 AND ExternalMoveID <> 32150 AND ExternalMoveID <> 32151 THEN\n            Robot.Outputs.MoveID := ExternalMoveID;\n            Sent := TRUE;\n        END_IF;\n        \n    ELSE (*Not External Control*)\n        IF Robot.Outputs.MoveID = 32150 THEN\n            Robot.Outputs.MoveID := 32151;\n        ELSIF Robot.Outputs.MoveID = 32151 THEN\n            Robot.Outputs.MoveID := 32150;\n        ELSIF Robot.Outputs.MoveID <> 32150 OR Robot.Outputs.MoveID <> 32151 THEN\n            Robot.Outputs.MoveID := 32150;\n        END_IF;\n        Sent := TRUE;\n    END_IF;\nEND_IF;\n\n(* Check if _Move has been sent, if so, check if it was received *)\nIF Sent THEN\n    IF Robot.Outputs.MotionCommand.MoveCommand = Meca500_MotionCommandID.SET_CONF THEN\n        IF Robot.Outputs.MotionCommand.Argument0 = Output_Params[1] AND Robot.Outputs.MotionCommand.Argument1 = Output_Params[2] AND Robot.Outputs.MotionCommand.Argument2 = Output_Params[3] AND Robot.Outputs.MotionCommand.Argument3 = Output_Params[4] AND Robot.Outputs.MotionCommand.Argument4 = Output_Params[5] AND Robot.Outputs.MotionCommand.Argument5 = Output_Params[6] THEN\n            IF Robot.Inputs.Motion.MoveID = Robot.Outputs.MoveID THEN\n                Buffered := TRUE;\n            END_IF;\n        END_IF;\n    END_IF;\nEND_IF;\n\n(*If External _Move ID is equal to Internal, raise an error*)\nIF ExternalMoveID = 32150 OR ExternalMoveID = 32151 THEN\n    Error := TRUE;\nEND_IF;\nFirstScan:=TRUE;","LineInfoPersistence":"(string)333b9f64-ae1a-4255-b850-ebc17895e63a_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK SetConf\nVAR_INPUT\n\tShoulder\t\t\t\t:\tREAL;\n\tElbow\t\t\t\t\t:\tREAL;\n\tWrist\t\t\t\t\t:\tREAL;\n\tExternalStatecontrol \t:\tBOOL;\n\tExternalMoveID\t\t\t:\tUINT;\nEND_VAR\nVAR_IN_OUT\n\tRobot\t:\tMeca500;\t\n\tSent\t\t:\tBOOL;\n\tBuffered\t:\tBOOL;\nEND_VAR\nVAR_OUTPUT\n\tError\t\t:\tBOOL;\nEND_VAR\nVAR\n\tOutput_Params\t:\tARRAY[1..6] OF REAL;\n\tFirstScan\t\t:\tBOOL;\nEND_VAR\n","LineInfoPersistence":"(string)333b9f64-ae1a-4255-b850-ebc17895e63a_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)221","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}