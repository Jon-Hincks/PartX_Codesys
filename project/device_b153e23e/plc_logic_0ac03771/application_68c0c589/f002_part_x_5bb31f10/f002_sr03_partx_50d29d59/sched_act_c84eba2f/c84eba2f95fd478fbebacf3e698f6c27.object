{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)c84eba2f-95fd-478f-beba-cf3e698f6c27","ParentGuid":"(Guid)50d29d59-1930-4d84-b547-11bb08373609","Name":"(string)SCHED_ACT","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)8ac092e5-3128-4e26-9e7e-11016c6684f2","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"8ac092e5","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// 1. Run the system blocks using the shared parent variables\nSchedTrigger(CLK := GVL.PARTX.SCHED);\nStateTimer();\n\n// 2. The Finite State Machine\nCASE CurrentState OF\n\n    E_SchedState.INIT:\n        GVL.PARTX.FWD := FALSE;\n        GVL.PARTX.REV := FALSE;\n        StateTimer(IN := FALSE); \n        CurrentState := E_SchedState.WAIT_FOR_START;\n\n    E_SchedState.WAIT_FOR_START:\n\t\tGVL.PARTX.FWD := FALSE;\n        GVL.PARTX.REV := FALSE;\n        IF SchedTrigger.Q THEN\n            CurrentState := E_SchedState.RUN_FORWARD;\n        END_IF;\n\n    E_SchedState.RUN_FORWARD:\n        GVL.PARTX.FWD := TRUE;\n        StateTimer(IN := TRUE, PT := T#5000MS);\n        \n        IF StateTimer.Q THEN\n            GVL.PARTX.FWD := FALSE;  \n            StateTimer(IN := FALSE); \n            CurrentState := E_SchedState.RUN_REVERSE;\n        END_IF;\n\n    E_SchedState.RUN_REVERSE:\n        GVL.PARTX.REV := TRUE;\n        StateTimer(IN := TRUE, PT := T#5000MS);\n        \n        IF StateTimer.Q THEN\n            GVL.PARTX.REV := FALSE;  \n            StateTimer(IN := FALSE); \n            CurrentState := E_SchedState.DONE;\n        END_IF;\n\t\tGVL.PARTX.SCHED:=FALSE;\n\n    E_SchedState.DONE:\n        CurrentState := E_SchedState.INIT;\n\nEND_CASE;","LineInfoPersistence":"(string)c84eba2f-95fd-478f-beba-cf3e698f6c27_Impl_LineIds"}}}},"UniqueIdGenerator":"(string)45"}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","8ac092e5":"{8ac092e5-3128-4e26-9e7e-11016c6684f2}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}