{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)c84eba2f-95fd-478f-beba-cf3e698f6c27","ParentGuid":"(Guid)50d29d59-1930-4d84-b547-11bb08373609","Name":"(string)SCHED_ACT","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)8ac092e5-3128-4e26-9e7e-11016c6684f2","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"8ac092e5","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// 1. Run the system blocks using the shared parent variables\nSchedTrigger(CLK := GVL.PARTX.SCHED);\nStateTimer();\n\n// 2. The Finite State Machine\nCASE CurrentState OF\n\n    E_SchedState.INIT:\n        GVL.PARTX.FWD := FALSE;\n        GVL.PARTX.REV := FALSE;\n        StateTimer(IN := FALSE); \n        StepIndex := 1; // Always start back at row 1\n        CurrentState := E_SchedState.WAIT_FOR_START;\n\n    E_SchedState.WAIT_FOR_START:\n        GVL.PARTX.FWD := FALSE;\n        GVL.PARTX.REV := FALSE;\n        \n        IF SchedTrigger.Q THEN\n            StepIndex := 1; // Reset to row 1 on a fresh trigger\n            CurrentState := E_SchedState.EXECUTE_STEP;\n        END_IF;\n\n    E_SchedState.EXECUTE_STEP:\n        // Check if this row's checkbox is actually turned ON\n        IF GVL.PARTX.Steps[StepIndex].StepEnable THEN\n            \n            // 1. Fire physical outputs based on the Dropdown integer (1=UP/FWD, 2=DOWN/REV)\n            IF GVL.PARTX.Steps[StepIndex].Direction = 1 THEN\n                GVL.PARTX.FWD := TRUE;\n                GVL.PARTX.REV := FALSE;\n\t\t\t\tGVL.PARTX.IDLE := FALSE;\n            ELSIF GVL.PARTX.Steps[StepIndex].Direction = 2 THEN\n                GVL.PARTX.FWD := FALSE;\n                GVL.PARTX.REV := TRUE;\n\t\t\t\tGVL.PARTX.IDLE := FALSE;\n            ELSE // 0 or anything else is IDLE\n                GVL.PARTX.FWD := FALSE;\n                GVL.PARTX.REV := FALSE;\n\t\t\t\tGVL.PARTX.IDLE := TRUE;\n            END_IF;\n\n            // 2. Convert the DINT milliseconds value from HMI into a standard PLC TIME format\n            StateTimer(IN := TRUE, PT := DINT_TO_TIME(GVL.PARTX.Steps[StepIndex].DurationMS));\n            \n            // 3. Step Timer Finished\n            IF StateTimer.Q THEN\n                // Shut outputs off immediately before moving to the next row\n                GVL.PARTX.FWD := FALSE;  \n                GVL.PARTX.REV := FALSE;\n                StateTimer(IN := FALSE); \n                CurrentState := E_SchedState.ADVANCE_STEP;\n            END_IF;\n            \n        ELSE\n            // If the checkbox is OFF, skip this row entirely and advance\n            CurrentState := E_SchedState.ADVANCE_STEP;\n        END_IF;\n\n    E_SchedState.ADVANCE_STEP:\n        // Move to the next row index\n        StepIndex := StepIndex + 1;\n        \n        // If we have finished processing all 4 rows, we are done. \n        // Otherwise, loop back to execute the next row.\n        IF StepIndex > 8 THEN \n            CurrentState := E_SchedState.DONE;\n        ELSE\n            CurrentState := E_SchedState.EXECUTE_STEP;\n        END_IF;\n\n    E_SchedState.DONE:\n        GVL.PARTX.SCHED := FALSE; // Drop master trigger\n        CurrentState := E_SchedState.INIT;\n\nEND_CASE;","LineInfoPersistence":"(string)c84eba2f-95fd-478f-beba-cf3e698f6c27_Impl_LineIds"}}}},"UniqueIdGenerator":"(string)122"}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","8ac092e5":"{8ac092e5-3128-4e26-9e7e-11016c6684f2}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}