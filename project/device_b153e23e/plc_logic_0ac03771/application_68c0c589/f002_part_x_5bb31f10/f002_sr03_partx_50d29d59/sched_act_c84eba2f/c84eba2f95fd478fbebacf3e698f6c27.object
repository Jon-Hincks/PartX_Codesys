{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)c84eba2f-95fd-478f-beba-cf3e698f6c27","ParentGuid":"(Guid)50d29d59-1930-4d84-b547-11bb08373609","Name":"(string)SCHED_ACT","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)8ac092e5-3128-4e26-9e7e-11016c6684f2","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"8ac092e5","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// 1. Run the system blocks using the shared parent variables\nSchedTrigger(CLK := GVL.PARTX.SCHED);\n\n// --- NEW ABORT LOGIC ---\n// If the schedule is turned off, and we aren't already waiting for a new start, force an abort.\nIF GVL.PARTX.MAN OR (NOT GVL.PARTX.SCHED AND CurrentState <> E_SchedState.WAIT_FOR_START AND CurrentState <> E_SchedState.INIT) THEN\n    fbRobotHandshake(xExecute := FALSE); // Safe reset of handshake byte IO lines if aborted\n    CurrentState := E_SchedState.INIT; \nEND_IF\n// -----------------------\n\n// Run the timer AFTER the abort check so it can be reset properly if needed\nStateTimer();\n\n// 2. The Finite State Machine\nCASE CurrentState OF\n\n    E_SchedState.INIT:\n        GVL.PARTX.FWD := FALSE;\n        GVL.PARTX.REV := FALSE;\n        GVL.PARTX.IDLE := TRUE;\n        GVL.PARTX.IDLE_Trigger := FALSE;\n        fbRobotHandshake(xExecute := FALSE); // Force the handshake POU back to its idle state\n        StateTimer(IN := FALSE); \n        StepIndex := 1; \n        CurrentState := E_SchedState.WAIT_FOR_START;\n\n    E_SchedState.WAIT_FOR_START:\n        GVL.PARTX.FWD := FALSE;\n        GVL.PARTX.REV := FALSE;\n        // ONLY allow the sequence to trigger if we are NOT in manual mode\n        IF SchedTrigger.Q AND NOT GVL.PARTX.MAN THEN\n            StepIndex := 1; \n            CurrentState := E_SchedState.EXECUTE_STEP;\n        ELSIF SchedTrigger.Q AND GVL.PARTX.MAN THEN\n            // Optional: Reset the schedule trigger if they try to start it while in manual\n            GVL.PARTX.SCHED := FALSE;\n        END_IF;\n\n    E_SchedState.EXECUTE_STEP:\n        // Check if this row's checkbox is actually turned ON\n        IF GVL.PARTX.Steps[StepIndex].StepEnable THEN\n            \n            // --- 1. ALWAYS RESET TRIGGER AT THE START OF THE SCAN ---\n            // This guarantees that if it was set TRUE on the previous scan, \n            // it turns OFF now, creating a perfect 1-scan rising edge pulse.\n            GVL.CAM_1.Trigger := FALSE; \n\n            // 2. Fire physical outputs based on the Dropdown integer\n            IF GVL.PARTX.Steps[StepIndex].Direction = 1 THEN\n                GVL.PARTX.FWD := TRUE;\n                GVL.PARTX.REV := FALSE;\n                GVL.PARTX.IDLE := FALSE;\n                GVL.PARTX.IDLE_Trigger := FALSE;\n\t\t\t\tGVL.PARTX.BOUNCE:=FALSE;\n            ELSIF GVL.PARTX.Steps[StepIndex].Direction = 2 THEN\n                GVL.PARTX.FWD := FALSE;\n                GVL.PARTX.REV := TRUE;\n                GVL.PARTX.IDLE := FALSE;\n                GVL.PARTX.IDLE_Trigger := FALSE;\n\t\t\t\tGVL.PARTX.BOUNCE:=FALSE;\n            ELSIF GVL.PARTX.Steps[StepIndex].Direction = 3 THEN\n                // IDLE_Trigger: All physical motion outputs off, system is waiting\n                GVL.PARTX.FWD := FALSE;\n                GVL.PARTX.REV := FALSE;\n                GVL.PARTX.IDLE := FALSE;\n                GVL.PARTX.IDLE_Trigger := TRUE;\n\t\t\t\tGVL.PARTX.BOUNCE:=FALSE;\n\t\t\tELSIF GVL.PARTX.Steps[StepIndex].Direction = 4 THEN\n                // IDLE_Trigger: All physical motion outputs off, system is waiting\n                GVL.PARTX.FWD := FALSE;\n                GVL.PARTX.REV := FALSE;\n                GVL.PARTX.IDLE := FALSE;\n                GVL.PARTX.IDLE_Trigger := FALSE;\n\t\t\t\tGVL.PARTX.BOUNCE:=TRUE;\n            ELSE // 0 or anything else is standard IDLE\n                GVL.PARTX.FWD := FALSE;\n                GVL.PARTX.REV := FALSE;\n                GVL.PARTX.IDLE := TRUE;\n                GVL.PARTX.IDLE_Trigger := FALSE;\n            END_IF;\n\n\t\t\t// 3. Run the step timer using the dynamically indexed duration\n            StateTimer(IN := TRUE, PT := DINT_TO_TIME(GVL.PARTX.Steps[StepIndex].DurationMS));\n            \n            // --- NEW: PRE-TRIGGER THE CAMERA ---\n            // If this is an IDLE_TRIGGER step, fire the camera 100ms before the timer finishes\n            IF GVL.PARTX.Steps[StepIndex].Direction = 3 THEN\n                IF StateTimer.ET >= (DINT_TO_TIME(GVL.PARTX.Steps[StepIndex].DurationMS) - T#100ms) THEN\n                    GVL.CAM_1.Trigger := TRUE;\n                END_IF;\n            END_IF;\n            \n            // 4. Step Timer Finished\n            IF StateTimer.Q THEN\n                // Clean up standard step tracking variables immediately\n                GVL.PARTX.FWD := FALSE;  \n                GVL.PARTX.REV := FALSE;\n                GVL.PARTX.IDLE_Trigger := FALSE; // Backlight turns off here safely\n                \n                StateTimer(IN := FALSE); \n                \n                // If it was a camera step, route to WAIT_FOR_CAMERA so data can settle\n                IF GVL.PARTX.Steps[StepIndex].Direction = 3 THEN\n                    CurrentState := E_SchedState.WAIT_FOR_CAMERA;\n                ELSE\n                    CurrentState := E_SchedState.ADVANCE_STEP;\n                END_IF;\n            END_IF;\n            \n        ELSE\n            // If the checkbox is OFF, skip this row entirely and advance\n            CurrentState := E_SchedState.ADVANCE_STEP;\n        END_IF;\n\n    E_SchedState.RUN_ROBOT_HANDSHAKE:\n        // Execute the standalone handshake block. Send Command 3 to the robot.\n        fbRobotHandshake(xExecute := TRUE, iCommandID := 3);\n        \n        IF fbRobotHandshake.xDone THEN\n            fbRobotHandshake(xExecute := FALSE); // Pull execution low to reset POU internal state\n            CurrentState := E_SchedState.ADVANCE_STEP;\n        ELSIF fbRobotHandshake.xError THEN\n            fbRobotHandshake(xExecute := FALSE);\n            CurrentState := E_SchedState.INIT;   // Route to master safety initialization if it times out\n        END_IF;\n\t\t\n\tE_SchedState.WAIT_FOR_CAMERA:\n        // Option A: If your camera has a \"New Data Ready\" or \"Acquisition Done\" bit, use it:\n        // IF GVL.CAM_1.xDataReady THEN\n        //     GVL.CAM_1.Trigger := FALSE; // Turn off trigger if you haven't already\n        //     CurrentState := E_SchedState.RUN_ROBOT_HANDSHAKE;\n        // END_IF;\n\n        // Option B: A simple settling timer to give the camera network time to update\n        StateTimer(IN := TRUE, PT := T#1500MS); // Adjust based on camera hardware spec\n        \n        IF StateTimer.Q THEN\n            StateTimer(IN := FALSE);\n            CurrentState := E_SchedState.RUN_ROBOT_HANDSHAKE;\n        END_IF;\n\n    E_SchedState.ADVANCE_STEP:\n        // Move to the next row index\n        StepIndex := StepIndex + 1;\n        \n        // If we have finished processing all rows, handle loop check or finish. \n        // Otherwise, loop back to execute the next row.\n        IF StepIndex > 8 THEN \n            IF GVL.PARTX.Loop_SCHED AND GVL.PARTX.SCHED AND NOT GVL.PARTX.MAN THEN\n                // Loop is active, master trigger is still on, and we aren't in manual mode:\n                // Instantly loop back to the first step without going to DONE or dropped outputs\n                StepIndex := 1;\n                CurrentState := E_SchedState.EXECUTE_STEP;\n            ELSE\n                // Loop is disabled or an abort condition is pending, go to standard finalization\n                CurrentState := E_SchedState.DONE;\n            END_IF;\n        ELSE\n            CurrentState := E_SchedState.EXECUTE_STEP;\n        END_IF;\n\n    E_SchedState.DONE:\n        // Standard non-looping end sequence\n        GVL.PARTX.SCHED := FALSE; // Drop master trigger\n        CurrentState := E_SchedState.INIT;\n\nEND_CASE;","LineInfoPersistence":"(string)c84eba2f-95fd-478f-beba-cf3e698f6c27_Impl_LineIds"}}}},"UniqueIdGenerator":"(string)1218"}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","8ac092e5":"{8ac092e5-3128-4e26-9e7e-11016c6684f2}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}