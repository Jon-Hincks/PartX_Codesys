{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)159758e6-0e20-4407-8bae-5c5f0e7b048c","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)Meca500_Errors","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)e969acc2-702c-40f3-a3de-2d604ce8e9eb"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string){attribute 'qualified_only'}\n{attribute 'strict'}\n///For more informations refer to page 52 of the documentation meca500-r4-programming-manual.\nTYPE Meca500_Errors :\n(\n\t ///No error currently.\n\t NO_ERROR := 0,\n\t\n\t ///Maximum number OF queued commands reached. Retry BY sending commands AT a slower rate.\n\t COMMAND_BUFFER_IS_FULL := 1000,\n\t\n\t ///Unknown or empty command.\n\t UNKNOWN_COMMAND := 1001,\n\t\n\t ///Syntax error or symbol missing. - Command: '...'] A parenthesis or a comma has been omitted.\n\t SYNTAX_ERROR := 1002, \n\t\n\t ///Wrong number of arguments or invalid input (e.g., the argument is out of range).\n\t ARGUMENT_ERROR := 1003,\n\t\n\t ///The robot must be activated.\n\t THE_ROBOT_IS_NOT_ACTIVATED := 1005,\n\t\n\t ///The robot must be homed.\n\t THE_ROBOT_IS_NOT_HOMED := 1006,\n\t\n\t ///The robot cannot reach the joint set or pose requested because of its joint limits.\n\t JOINT_OVER_LIMIT := 1007, \n\t \n\t ///The linear motion cannot be executed because it requires a reorientation of 180° of the end-effector,\n\t ///and there may be two possible paths.\n\t SINGULARITY_DETECTED_ROTATE:=1010,\n\t\n\t ///A command has been sent but the robot is in error mode and cannot process it until a ResetError command is sent.\n\t THE_ROBOT_IS_IN_ERROR := 1011,\n\t\n\t ///The MoveLin command sent requires that the robot pass through a singularity, or the MovePose command sent requires that the robot goes to a singular robot posture.\n\t SINGULARITY_DETECTED_REORIENTATION := 1012,\n\t\n\t ///Activation failed. Try again. \n\t ACTIVATION_FAILED := 1013,\n\t\n\t ///Homing procedure failed. Try again.\n\t HOMING_FAILED := 1014,\n\t\n\t ///The pose requested in the MoveLin or MovePose commands cannot be reached by the robot (even if the robot had no joint limits).\n\t POSE_OUT_OF_REACH := 1016,\n\t\n\t ///Problem with communication.\n\t COMMUNICATION_FAILED := 1017,\n\t\n\t ///Missing NULL character at the end of a command.\n\t MISSING_NULL := 1018,\n\t\n\t ///Something is wrong. The brakes cannot be engaged. Try again.\n\t BRAKES_CANNOT_BE_RELEASED := 1020,\n\t\n\t ///Something is wrong. The deactivation failed. Try again.\n\t DEACTIVATION_FAILED := 1021,\n\t\n\t ///The command StopSaving was sent, but the robot was not saving a program.\n\t PROGRAM_SAVING_FAILED_1 := 1022,\n\t\n\t ///The command cannot be executed in the offline program.\n\t IGNORING_COMMAND_FOR_OFFLINE_MODE := 1023,\n\t\n\t ///Somehow, mastering was lost. Contact Mecademic.\n\t MASTERING_NEEDED := 1024,\n\t\n\t ///Turn off the robot, then turn it back on in order to reset the error.\n\t RESET_ERROR_NOT_POSSIBLE := 1025, \n\t\n\t ///The robot must be deactivated in order to execute this command.\n\t DEACTIVATION_NEEDED := 1026,\n\t\n\t ///The robot must be deactivated in order to execute this command.\n\t CHANGE_SIMULATION_MODE_FAILED := 1027,\n\t\n\t ///Error on the network. Resend the command.\n\t NETWORK_ERROR := 1028,\n\t\n\t ///Maximum program size is 13,000 commands. Saving stopped - Memory full.\n\t OFFLINE_PROGRAM_FULL := 1029,\n\t\n\t ///The robot is already saving a program. Wait until finished to save another program.\n\t ALREADY_SAVING := 1030,\n\t\n\t ///The command cannot be executed because the robot is currently saving a program.\n\t PROGRAM_SAVING_ABORTED := 1031,\n\t \n\t ///Requested move blocked because start robot position is not in the requested configuration.\n\t START_CONF_MISMATCH := 1033,\n\t\n\t ///No gripper was detected.\n\t ERR_NO_GRIPPER_CONNECTED := 1038,\n\t \n\t ///General error for various commands.\n\t COMMAND_FAILED := 1040,\n\t \n\t ///No pneumatic model connected.\n\t NO_VBOX := 1041,\n\t \n\t ///Switching external tool type is only possible when the robot is deactivated.\n\t EXT_TOOL_SIM_MUST_DEACT := 1042,\n\t\n\t  ///If the gripper was forcing when this message appeared, most probably an overheating occurred. \n\t ///Let the gripper cool down for a few minutes and send the ResetError command. \n\t ///Note that the gripper will stop applying a force, so if it was holding a part, the part might fall.\n\t GRIPPER_ERROR := 3025,\n\t \n\t ///A hardware problem was detected. Mecademic cannot guaranty correct movements - Please contact Mecademic.\n\t MAINTENANCE_CHECK_DISCOVERED_A_PROBLEM := 3026,\n\t \n\t ///A communication error with the pneumatic module was detected. Contact Mecademic.\n\t PNEUMATIC_ERROR := 3037\n);\nEND_TYPE\n","LineInfoPersistence":"(string)159758e6-0e20-4407-8bae-5c5f0e7b048c_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)231"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}