{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)766b0427-8318-4779-974a-3e310b6253e9","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)Meca500_DynamicDataTypeID","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)e969acc2-702c-40f3-a3de-2d604ce8e9eb"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string){attribute 'qualified_only'}\n{attribute 'strict'}\n///For more informations refer to page 75 of the documentation meca500-r4-programming-manual.\nTYPE Meca500_DynamicDataTypeID :\n(\n\t///Robot will automatically choose dynamic data type and change it every cycle to go through\n\t///them all. This is the easiest way for the host to receive all possible values periodically (round-robin\n\t///manner).\n\tAUTOMATIC:=0,\n\t\n\t///Firmware version. Values: [major version, minor version, patch version, build number]. Same as\n\t///GetFwVersion.\n\tFIRMWARE_VERSION:=1,\n\t\n\t///Product type. Values: [product type (3=Meca500)]. Same as GetProductType.\n\tPRODUCT_TYPE:=2,\n\t\n\t///Serial number. Values: [serial number]. Same as GetRobotSerial.\n\tSERIAL_NUMBER:=3,\n\t\n\t///Joints offset (as calculated by mastering at production). Values: [δθ1, δθ2, δθ3, δθ4, δθ5, δθ6]. In degrees.\n\tGET_JOINTS_OFFSET:=4,\n\t\n\t///Joint limits enabled state. Values: [enabled 1/0]. Same as GetJointLimitsCfg.\n\tGET_JOINT_LIMITS_CFG:=11,\n\t\n\t///Robot model's nominal joint limits for joints 1, 2 and 3. Values: [θ1,min, θ1,max, θ2,min, θ2,max, θ3,min, θ3,max].\n\t///Unit is degrees. Same as GetModelJointLimits.\n\tGET_MODEL_JOINT_1_TO_3_LIMITS:=12,\n\t\n\t///Robot model's nominal joint limits for joints 4, 5 and 6. Values: [θ4,min, θ4,max, θ5,min, θ5,max, θ6,min, θ6,max].\n\t///Unit is degrees. Same as GetModelJointLimits.\n\tGET_MODEL_JOINT_4_TO_6_LIMITS:=13,\n\t\n\t///Effective joint limits for joints 1, 2 and 3. Values: [θ1,min, θ1,max, θ2,min, θ2,max, θ3,min, θ3,max]. Unit is degrees.\n\t///Same as GetJointLimits.\n\tGET_EFF_JOINT_1_to_3_LIMITS:=14,\n\t\n\t///Effective joint limits for joints 4, 5 and 6. Values: [θ4,min, θ4,max, θ5,min, θ5,max, θ6,min, θ6,max]. Unit is degrees.\n\t///Same as GetJointLimits.\n\tGET_EFF_JOINT_4_TO_6_LIMITS:=15,\n\t\n\t///Current workspace limits configuration. Values: [workspace limits severity, workspace limits detection mode].\n\t///Same as GetWorkspaceLimitsCfg.\n\tGET_WORKSPACE_LIMITS_CFG:=17,\n\t\n\t///Current workspace Limits. Values: [xmin, ymin, zmin, xmax, ymax, zmax]. Units is mm. Same as\n\t///GetWorkspaceLimits.\n\tGET_WORKSPACE_LIMITS:=18,\n\t\n\t///Tool Sphere model. Values: [x, y, z, r]. Units in mm. Same as GetToolSphere.\n\tGET_EFF_TOOL_SPHERE:=19,\n\t\n\t///Motion queue's conf that will be applied to next MovePose. Values: [shoulder −1/1/NaN, elbow −1/1/NaN,\n\t///wrist −1/1/NaN, last joint turn or NaN]. Value NaN is used to indicate auto-conf or auto-conf-turn. Same as\n\t///GetConf and GetConfTurn.\n\tGET_MOTION_QUEUE_CONF:=20,\n\t\n\t///Motion queue parameters. Values: [blending ratio percent, velocity timeout in seconds]. Same as\n\t///GetBlending AND GetVelTimeout.\n\tGET_MOTION_QUEUE_PARAM:=21,\n\t\n\t///Motion queue velocities and accelerations in percent. Values: [joint velocity, joint acceleration, Cartesian\n\t///linear velocity, Cartesian angular velocity, Cartesian acceleration]. Unit is percent. Same as GetJointVel,\n\t///GetJointAcc, GetCartLinVel, GetCartAngVel, and GetCartAcc.\n\tGET_MOTION_PARAM:=22,\n\t\n\t///Gripper parameters. Values: [gripper force, gripper velocity, fingers opening corresponding to closed state,\n\t///fingers opening corresponding to open state]. Arguments 1 and 2 are in percentage, while arguments 3\n\t///and 4 are in mm. Same as GetGripperForce, GetGripperVel, and GetGripperRange.\n\tGET_GRIPPER_PARAM:=23,\n\t\n\t///Torque limits configuration. Values: [severity, detection mode]. See Section 2.1.28 of programming manual for corresponding\n\t///severity/mode values. Same as GetTorqueLimitsCfg.\n\tGET_TORQUE_LIMITS_CFG:=24,\n\t\n\t///Torque limits. Values: [joint 1 limit, joint 2 limit, ..., joint 6 limit]. Unit is percent. Same as GetTorqueLimits.\n\tGET_TORQUE_LIMITS:=25,\n\t\n\t///Target real-time joint velocity. Values: [θ̇ 1, θ̇ 2, θ̇ 3, θ̇ 4, θ̇ 5, θ̇ 6]. Unit is °/s. Same as GetRtTargetJointVel.\n\tGET_RT_TARET_JOINT_VEL:=32,\n\t\n\t///Target real-time joint torque (not implemented yet). Values: [joint 1 torque, joint 2 torque, ..., joint 6\n\t///torque]. Unit is percent. Same as GetRtTargetJointTorq.\n\tGET_RT_TARGET_JOINT_TORQ:=33,\n\t\n\t///Target real-time Cartesian velocity (TRF with respect to. WRF). Values: [ẋ , ẏ , ż, ωx, ωy, ωz]. Units are mm/s\n\t///or °/s. Same as GetRtTargetCartVel.\n\tGET_RT_TARGET_CART_VEL:=34,\n\t\n\t///Actual real-time joint position based on hardware encoders. Values: [θ1, θ2, θ3, θ4, θ5, θ6]. Unit is degrees.\n\t///Same as GetRtJointPos.\n\tGET_RT_JOINT_POS:=40,\n\t\n\t///Actual real-time end-effector pose (TRF with respect to. WRF). Values: [x, y, z, α, β, γ]. Units are mm or\n\t///degrees. Same as GetRtCartPos.\n\tGET_RT_CART_POS:=41,\n\t\n\t///Actual real-time joint velocity. Values: [θ̇ 1, θ̇ 2, θ̇ 3, θ̇ 4, θ̇ 5, θ̇6]. Unit is °/s. Same as GetRtJointVel.\t\n\tGET_RT_JOINT_VEL:=42,\n\t\n\t///Actual REAL-TIME joint torque. Values: [joint 1 torque, joint 2 torque, ..., joint 6 torque]. Unit is percent.\n\t///Same as GetRtJointTorq.\n\tGET_RT_JOINT_TORQ:=43,\n\t\n\t///Actual real-time cartesian velocity (TRF with respect to. WRF). Values: [ẋ , ẏ , ż, ωx, ωy, ωz]. Units are mm/s\n\t///or °/s. Same as GetRtCartVel.\n\tGET_RT_CART_VEL:=44,\n\t\n\t///Actual conf that corresponds to real-time end-effector pose. Values: [shoulder −1/0/1, elbow −1/0/1, \n\t///wrist−1/0/1, last joint turn]. Same as GetRtConf and GetRtConfTurn.\n\tGET_RT_CONF:=45,\n\t\n\t///Accelerometer reading. Values: [ax, ay, az]. Unit is 1/16,000 of G. Same as GetRtAccelerometer.\n\tGET_RT_ACCELOMETER:=46,\n\t\n\t///External tool status. Values: [type, homing done, error state, overheated]. Same as GetRtExtToolStatus.\n\tGET_RT_EXT_TOOL_STATUS:=52,\n\t\n\t///EOAT status. Values if type gripper: [holding part, desired fingers opening reached, gripper closed, gripper\n\t///open, gripper force, fingers opening]. Values if pneumatic module: [valve 1 state, valve 2 state].\n\tGET_EOT_STATUS:=53\n\n);\nEND_TYPE\n","LineInfoPersistence":"(string)766b0427-8318-4779-974a-3e310b6253e9_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)374"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}