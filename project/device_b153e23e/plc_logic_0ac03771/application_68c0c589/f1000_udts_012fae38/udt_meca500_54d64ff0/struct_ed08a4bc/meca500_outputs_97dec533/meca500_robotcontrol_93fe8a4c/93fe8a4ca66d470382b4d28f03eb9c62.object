{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)93fe8a4c-a66d-4703-82b4-d28f03eb9c62","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)Meca500_RobotControl","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)97dec533-71f2-4578-bda6-01ebd4dbff36"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)TYPE Meca500_RobotControl :\nSTRUCT\n\tDeactivate\t\t\t:\tBIT;\t//Deactivates the robot when set to True.\t\n\tActivate\t\t\t:\tBIT;\t//Activates the robot when set to True(only if Deactivate bit is False).\n\tHome\t\t\t\t:\tBIT;\t//Homes the robot when set to True (if activated but not homed).\n\tResetError\t\t\t:\tBIT;\t//Resets the error when set to True.\n\tEnableSimulation\t:\tBIT;\t//Enables(True) OR disables(False) the simulation mode (only applied when the robot is deactivated).\n\tEnableRecoverymode\t:\tBIT;\t//Enables(True) or disables(False) the recovery mode.\n\tReserved6\t\t\t:\tBIT;\n\tReserved7\t\t\t:\tBIT;\n\tReserved8\t\t\t:\tBIT;\n\tReserved9\t\t\t:\tBIT;\n\tReserved10\t\t\t:\tBIT;\n\tReserved11\t\t\t:\tBIT;\n\tReserved12\t\t\t:\tBIT;\n\tReserved13\t\t\t:\tBIT;\n\tReserved14\t\t\t:\tBIT;\n\tReserved15\t\t\t:\tBIT;\n\tReserved16\t\t\t:\tBIT;\n\tReserved17\t\t\t:\tBIT;\n\tReserved18\t\t\t:\tBIT;\n\tReserved19\t\t\t:\tBIT;\n\tReserved20\t\t\t:\tBIT;\n\tReserved21\t\t\t:\tBIT;\n\tReserved22\t\t\t:\tBIT;\n\tReserved23\t\t\t:\tBIT;\n\tReserved24\t\t\t:\tBIT;\n\tReserved25\t\t\t:\tBIT;\n\tReserved26\t\t\t:\tBIT;\n\tReserved27\t\t\t:\tBIT;\n\tReserved28\t\t\t:\tBIT;\n\tReserved29\t\t\t:\tBIT;\n\tReserved30\t\t\t:\tBIT;\n\tReserved31\t\t\t:\tBIT;\n\t\nEND_STRUCT\nEND_TYPE\n","LineInfoPersistence":"(string)93fe8a4c-a66d-4703-82b4-d28f03eb9c62_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)49"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}