{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)320e8cd1-eece-4e4a-beab-b48eb497b533","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)Meca500_RobotStatus","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)5964f8dd-00da-44ec-af0b-9c3fb1572e0e"}]}}}}]},"TypeGuid":"(Guid)2db5746d-d284-4425-9f7f-2663a34b0ebc","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"2db5746d","@Value":{"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)TYPE Meca500_RobotStatus :\nSTRUCT \n\tBusy \t\t\t: \tBIT;\t//True only while the robot is being activated, homed or deactivated.\n\tActivated \t\t:\tBIT;\t//Indicates whether the motors are on (powered).\n\tHomed\t\t\t:\tBIT;\t//Indicates whether the robot is homed and ready to receive motion commands.\n\tSimActivated\t:\tBIT;\t//Indicates whether the robot simulation mode is activated.\n\tBrakesEngaged\t:\tBIT;\t//Indicates whether the brakes are engaged.\n\tRecoverymode\t:\tBIT;\t//Indicates whether the robot recovery mode is activated.\n\tEStop\t\t\t:\tBIT;\t//Indicates whether the E-Stop is activated (Meca500 R4 only).\n\tReserved7\t\t:\tBIT;\n\tReserved8\t\t:\tBIT;\n\tReserved9\t\t:\tBIT;\n\tReserved10\t\t:\tBIT;\n\tReserved11\t\t:\tBIT;\n\tReserved12\t\t:\tBIT;\n\tReserved13\t\t:\tBIT;\n\tReserved14\t\t:\tBIT;\n\tReserved15\t\t:\tBIT;\n\nEND_STRUCT\nEND_TYPE\n","LineInfoPersistence":"(string)320e8cd1-eece-4e4a-beab-b48eb497b533_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)22"}},"TypeInfos":{"2db5746d":"{2db5746d-d284-4425-9f7f-2663a34b0ebc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}