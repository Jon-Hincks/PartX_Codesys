{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)ed70538c-0746-4983-8370-41819c4f9b0d","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)RobotHandshake","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)ac4511da-0200-4591-a50f-e24423501314"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)// Safety Timeout: If the robot gets stuck mid-handshake for more than 30 seconds, trip a fault\ntonTimeout(IN := (iHandshakeState > 0 AND iHandshakeState < 100), PT := T#30s);\nIF tonTimeout.Q THEN\n    iHandshakeState := 999;\nEND_IF\n\nCASE iHandshakeState OF\n\n    0: (* IDLE *)\n        xDone  := FALSE;\n        xBusy  := FALSE;\n        \n        IF xExecute THEN\n            xBusy := TRUE;\n            xError := FALSE;\n            iHandshakeState := 10;\n        END_IF;\n\n    10: (* STEP 1: Fire Explicit Message to Write Coords *)\n        // Kick off your explicit messaging routine \n        GVL.Explicit.xTriggerWrite := TRUE; \n        iHandshakeState := 15;\n\n    15: (* STEP 1.5: Wait for Explicit Write to Complete *)\n        // Assumes your explicit messaging block sets xTriggerWrite back to FALSE when done.\n        // If it uses a separate \"Done\" flag (e.g., GVL.Explicit.xWriteDone), use that here instead!\n        IF NOT GVL.Explicit.xTriggerWrite THEN\n            // Coords are successfully in the Fanuc registers! Now send the execution command.\n            GVL.Robot.CMD := INT_TO_BYTE(iCommandID); \n            iHandshakeState := 20;\n        END_IF;\n\n    20: (* STEP 2: Wait for Robot Echo AND ensure previous Complete flag is dropped *)\n        // Since we aren't using a BUSY bit, we must ensure the robot echoes our command \n        // AND its COMPLETE byte has dropped back to 0. This prevents skipping steps!\n        IF (GVL.Robot.ECHO = GVL.Robot.CMD) AND (GVL.Robot.COMPLETE = 0) THEN\n            iHandshakeState := 40;\n        END_IF;\n\n    40: (* STEP 4: Wait for Robot Completion *)\n        // Wait until the robot sets its COMPLETE byte to 1\n        IF GVL.Robot.COMPLETE = 1 THEN\n            GVL.Robot.ACK_Complete := 1; // Send 1 (True) as a byte to ACK the robot\n            iHandshakeState := 50;\n        END_IF;\n\n    50: (* STEP 5: Interlocking Reset *)\n        // Wait for the robot to see our ACK and clear its COMPLETE byte back to 0\n        IF GVL.Robot.COMPLETE = 0 THEN\n            GVL.Robot.ACK_Complete := 0; // Clear our acknowledgement byte back to 0\n            GVL.Robot.CMD          := 0; // Reset our command register byte back to 0\n            iHandshakeState        := 100;\n        END_IF;\n\n    100: (* HANDSHAKE COMPLETE *)\n        xBusy := FALSE;\n        xDone := TRUE;\n        \n        // Wait for the master scheduler to drop xExecute before dropping back to IDLE\n        IF NOT xExecute THEN\n            iHandshakeState := 0;\n        END_IF;\n\n    999: (* FAULT HANDLING *)\n        xBusy  := FALSE;\n        xError := TRUE;\n        \n        // Force cleanup of all IO bytes and explicit triggers on failure\n        GVL.Robot.ACK_Complete     := 0;\n        GVL.Robot.CMD              := 0;\n        \n        IF NOT xExecute THEN\n            iHandshakeState := 0;\n        END_IF;\n\nEND_CASE;","LineInfoPersistence":"(string)ed70538c-0746-4983-8370-41819c4f9b0d_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)FUNCTION_BLOCK RobotHandshake\nVAR_INPUT\n    xExecute      : BOOL;    // Kicked off by the Scheduler when it's time to talk\n    iCommandID    : INT;     // The Command number to send (e.g., 3)\nEND_VAR\nVAR_OUTPUT\n    xBusy         : BOOL;    // Handshake sequence is running\n    xDone         : BOOL;    // Handshake completed successfully\n    xError        : BOOL;    // Handshake faulted / timed out\nEND_VAR\nVAR\n    iHandshakeState : INT := 0;\n    tonTimeout      : TON;   // Safety timer so the PLC doesn't hang if the robot faults\nEND_VAR","LineInfoPersistence":"(string)ed70538c-0746-4983-8370-41819c4f9b0d_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)163","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}