{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)29f46184-8509-4b94-828b-70f5e51e1b9d","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)F001_SR08_Explicit_Messaging","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)829a18f2-c514-4f6e-9634-1df173429203","@Value":{"@Type":"829a18f2","@Value":{"ParentObjects":{"@Type":"fa2ee218:IDictionary","@Value":[{"@Key":"(Guid)d9b2b2cc-ea99-4c3b-aa42-1e5c49e65b84","@Value":"(Guid)ac4511da-0200-4591-a50f-e24423501314"}]}}}}]},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","829a18f2":"{829a18f2-c514-4f6e-9634-1df173429203}","fa2ee218":"{fa2ee218-a39b-4b6d-b249-49dbddbd168a}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)CASE iState OF\n    \n    0: (* IDLE STATE: Wait for the user trigger *)\n        IF GVL.Explicit.xTriggerWrite THEN\n            // 1. Snapshot the live GVL values into our local loop array\n            aWriteValues[1] := GVL.CAM_1.RESULT_POSX;\n            aWriteValues[2] := GVL.CAM_1.RESULT_POSY;\n            aWriteValues[3] := GVL.CAM_1.RESULT_POSZ;\n            aWriteValues[4] := GVL.CAM_1.RESULT_POSRX;\n            aWriteValues[5] := GVL.CAM_1.RESULT_POSRY;\n            aWriteValues[6] := GVL.CAM_1.RESULT_POSRZ;\n            \n            // 2. Set up initial loop states\n            iIndex := 1;          // Start at Attribute 1 (X)\n            \n            // 3. Clear global status flags before starting\n            GVL.Explicit.xWriteDone  := FALSE;\n            GVL.Explicit.xWriteError := FALSE;\n            \n            iState := 10;         // Move to transmission step\n        END_IF\n        \n    10: (* PREPARE DATA: Load value and fire execution pulse *)\n        rCurrentValue := aWriteValues[iIndex];\n        \n        // Execute the block with xExecute := TRUE\n        fbSetAttributeSingle(\n            xExecute            := TRUE,\n            itfEtherNetIPDevice := FANUC_Robot,\n            eClass              := 16#6C,             // Position Register Class\n            dwInstance          := 1,                 // Target PR[1] on the Fanuc\n            wAttribute          := iIndex,            // Cycles 1 to 6 (X, Y, Z, RX, RY, RZ)\n            tTimeOut            := T#1s,\n            pData               := ADR(rCurrentValue),\n            udiDataSize         := 4                  \n        );\n        \n        iState := 20; // Transition to wait state\n\n    20: (* WAIT FOR FB HANDSHAKE *)\n        // Keep processing the block cyclically\n        fbSetAttributeSingle();\n        \n        IF fbSetAttributeSingle.xDone THEN\n            IF iIndex >= 6 THEN\n                // All 6 values successfully sent to the PR\n                fbSetAttributeSingle(xExecute := FALSE);\n                iState := 100; \n            ELSE\n                // Move to the intermediate reset state to clear the edge detector\n                iState := 15; \n            END_IF\n            \n        ELSIF fbSetAttributeSingle.xError THEN\n            fbSetAttributeSingle(xExecute := FALSE);\n            iState := 999; \n        END_IF\n\n    15: (* EDGE DETECTOR RESET STATE *)\n        // Force xExecute to FALSE and process the FB for exactly one cycle.\n        // This guarantees the FB registers the falling edge before looping back to State 10.\n        fbSetAttributeSingle(xExecute := FALSE);\n        \n        iIndex := iIndex + 1; // Increment to next coordinate attribute\n        iState := 10;         // Jump back to fire the next transmission safely\n\n    100: (* SEQUENCE COMPLETE *)\n        GVL.Explicit.xWriteDone := TRUE; \n\t\tGVL.Explicit.xTriggerWrite := FALSE; // Lower user trigger\n        iState := 0; // Return smoothly to Idle\n\t\t\n\n    999: (* FAULT HANDLING *)\n        GVL.Explicit.xWriteError := TRUE;\n        // iState := 0; \n\nEND_CASE\n\n// =================================================================\n// CONTINUOUS STATUS MAPPING \n// =================================================================\nGVL.Explicit.xWriteBusy      := fbSetAttributeSingle.xBusy;\nGVL.Explicit.eWriteErrorCode := fbSetAttributeSingle.eError;","LineInfoPersistence":"(string)29f46184-8509-4b94-828b-70f5e51e1b9d_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)PROGRAM F001_SR08_Explicit_Messaging\nVAR\n    // State machine control\n    iState       : INT := 0; \n    iIndex       : WORD := 1; // Cycles from 1 to 6\n    \n    // Local array buffer to hold the 6 camera values\n    aWriteValues : ARRAY[1..6] OF REAL; \n    \n    // Active buffer variable for the current pointer address\n    rCurrentValue : REAL;\n    \n    // Pure ST Instance of the EtherNet/IP Function Block\n    fbSetAttributeSingle : ENIP.Set_Attribute_Single;\nEND_VAR","LineInfoPersistence":"(string)29f46184-8509-4b94-828b-70f5e51e1b9d_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)402","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}