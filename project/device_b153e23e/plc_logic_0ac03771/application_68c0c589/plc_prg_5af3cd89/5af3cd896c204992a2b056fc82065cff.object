{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)5af3cd89-6c20-4992-a2b0-56fc82065cff","ParentGuid":"(Guid)68c0c589-1454-4940-a0fa-28285bdee08c","Name":"(string)PLC_PRG","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)6f9dac99-8de1-4efc-8465-68ac443b7d08","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"6f9dac99","@Value":{"SpecialFunc":{"@Type":"0db3d7bb:Enum","@Value":"None"},"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)\n\n\n\n//**********************************************************************************************************//\n//Demo program using only the robot outputs\n//Activate StartSequence to Start Demo\nIF GVL.Meca500_1.Inputs.Status.RobotStatus.Activated AND GVL.Meca500_1.Inputs.Status.RobotStatus.Homed THEN\n\tIF StartSequence THEN\n\t\tGVL.Meca500_1.Outputs.MoveID:=1;\n\t\tSequenceStep := 10;\n\tEND_IF\t\t\n\t\n\tCASE SequenceStep OF\n\t\t\t//MoveJoints(0,0,0,0,0,0)\n\t\t10:\tGVL.Meca500_1.Outputs.MotionControl.SetPoint:=TRUE;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.MoveCommand:=1;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument0:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument1:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument2:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument3:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument4:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument5:=0;\n\t\t\tGVL.Meca500_1.Outputs.MoveID:=10;\n\t\t\tStartSequence:=FALSE;\t\n\t\t\tSequenceStep:=20;\n\t\t\t\n\t\t\t//MovePose(170,50,150,0,90,0)\n\t\t20:\tGVL.Meca500_1.Outputs.MotionCommand.MoveCommand:=2;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument0:=170;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument1:=50;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument2:=150;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument3:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument4:=90;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument5:=0;\n\t\t\tGVL.Meca500_1.Outputs.MoveID:=20;\n\t\t\tSequenceStep:=30;\n\t\t\t\n\t\t\t//MoveLin(170,-50,150,0,90,0)\n\t\t30:\tGVL.Meca500_1.Outputs.MotionCommand.MoveCommand:=3;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument0:=170;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument1:=-50;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument2:=150;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument3:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument4:=90;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument5:=0;\n\t\t\tGVL.Meca500_1.Outputs.MoveID:=30;\n\t\t\tSequenceStep:=40;\n\t\t\t\n\t\t\t//MoveLin(270,-50,150,0,90,0)\n\t\t40:\tGVL.Meca500_1.Outputs.MotionCommand.MoveCommand:=3;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument0:=270;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument1:=-50;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument2:=150;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument3:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument4:=90;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument5:=0;\n\t\t\tGVL.Meca500_1.Outputs.MoveID:=40;\n\t\t\tSequenceStep:=50;\n\t\t\t\n\t\t\t//MoveLin(270,50,150,0,90,0)\n\t\t50:\tGVL.Meca500_1.Outputs.MotionCommand.MoveCommand:=3;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument0:=270;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument1:=50;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument2:=150;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument3:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument4:=90;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument5:=0;\n\t\t\tGVL.Meca500_1.Outputs.MoveID:=50;\n\t\t\tSequenceStep:=60;\n\t\t\n\t\t\t//MoveLin(170,50,150,0,90,0)\n\t\t60:\tGVL.Meca500_1.Outputs.MotionCommand.MoveCommand:=3;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument0:=170;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument1:=50;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument2:=150;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument3:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument4:=90;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument5:=0;\n\t\t\tGVL.Meca500_1.Outputs.MoveID:=60;\n\t\t\tSequenceStep:=70;\n\t\t\t\n\t\t\t//MoveJoints(0,0,0,0,0,0)\n\t\t70:\tGVL.Meca500_1.Outputs.MotionCommand.MoveCommand:=1;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument0:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument1:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument2:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument3:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument4:=0;\n\t\t\tGVL.Meca500_1.Outputs.MotionCommand.Argument5:=0;\n\t\t\tGVL.Meca500_1.Outputs.MoveID:=70;\t\n\t\t\tSequenceStep:=80;\n\t\t\t\n\t\t80:GVL.Meca500_1.Outputs.MotionControl.SetPoint:=FALSE;\n\t\t\tSequenceStep:=0;\t\n\t\t\t\n\t\t\t\n\tEND_CASE\t\n\nEND_IF\t\n\n//******************************************************************************************************************//\n//Demo program using intructions\n//Activate TestSquareMove to Start Demo\nIF TestSquareMove THEN\n\t//Activate the robot if not activated\n\tGVL.Meca500_1.Outputs.RobotControl.Deactivate := false;\n\tIF GVL.Meca500_1.Inputs.Status.RobotStatus.Activated THEN \n\t\tGVL.Meca500_1.Outputs.RobotControl.Activate := FALSE;\n\tELSE\t\n\t\tGVL.Meca500_1.Outputs.RobotControl.Activate := TRUE;\t\n\tEND_IF\n\t\n\t//Home the robot if not home\n\tIF GVL.Meca500_1.Inputs.Status.RobotStatus.Homed THEN\n\t\tGVL.Meca500_1.Outputs.RobotControl.Home:=FALSE;\n\tELSE\n\t\tGVL.Meca500_1.Outputs.RobotControl.Home:=TRUE;\n\tEND_IF\n\n\tIF\tGVL.Meca500_1.Inputs.Status.RobotStatus.Activated AND GVL.Meca500_1.Inputs.Status.RobotStatus.Homed THEN\n\t\t\tCASE StepSquareMove OF\n\t\t\t0:\tStepSquareMove:=1; //Unused Step\n\t\t\tSetCartLinVel(\n\t\t\t\tVelocity_limit:=10,\n\t\t\t\tRobot:=GVL.Meca500_1,\n\t\t\t\tSent:=Sent,\n\t\t\t\tError=>Error,\n\t\t\t\tBuffered:=Buffered\n\t\t\t\t);\n\t\t\t1:\tStepSquareMove:=2; //Unused Step\n\t\t\t2:\tMoveJoints(\n\t\t\t\t\tJoint_Angle:= ZeroJointsValues, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= GVL.Meca500_1 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered);\n\t\t\t\t\n\t\t\t3:\tSetCheckpoint(\n\t\t\t\t\tCheckpointID:=3, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= GVL.Meca500_1 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered);\t\n\t\t\t4:\t\tIF gvl.Meca500_1.Inputs.Motion.CheckPoint=720899 THEN\n\t\t\t\t\tStepSquareMove:=5;\n\t\t\t\tEND_IF\t\n\t\t\t\t//StepSquareMove:=5;\n\t\t\t\t\n\t\t\t5:\tMovePose(\n\t\t\t\t\tPose:= MovePoseValues, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= 0 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered); \n\t\t\t6:\tMoveLin(\n\t\t\t\t\tPose:= MoveLinValues1, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= GVL.Meca500_1 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered);\n\t\t\t7:\tMoveLin(\n\t\t\t\t\tPose:= MoveLinValues2, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= GVL.Meca500_1 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered);\n\t\t\t8:\tMoveLin(\n\t\t\t\t\tPose:= MoveLinValues3, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= GVL.Meca500_1 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered);\n\t\t\t9:\tMoveLin(\n\t\t\t\t\tPose:= MoveLinValues4, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= GVL.Meca500_1 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered);\n\t\t\t10:\tMoveJoints(\n\t\t\t\t\tJoint_Angle:= ZeroJointsValues, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= GVL.Meca500_1 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered);\n\t\t\t11:\tSetCheckpoint(\n\t\t\t\t\tCheckpointID:=11, \n\t\t\t\t\tExternalStatecontrol:=0 , \n\t\t\t\t\tExternalMoveID:=0 , \n\t\t\t\t\tRobot:= GVL.Meca500_1 , \n\t\t\t\t\tError=> Error, \n\t\t\t\t\tSent:= Sent, \n\t\t\t\t\tBuffered:= Buffered);\t\n\t\t\t12:\tIF gvl.Meca500_1.Inputs.Motion.CheckPoint=720907 THEN\n\t\t\t\t\tStepSquareMove:=13;\n\t\t\t\tEND_IF\n\t\t\t\t//StepSquareMove:=13;\n\t\t\t13:\tStepSquareMove:=0;\t\t\t\n\t\t\t\n\t\t\tEND_CASE\n\t\t\t\n\t\t\t//When command is sent and buffered, Reset those tag and go to next step\n\t\t\tIF Sent AND Buffered THEN\n\t\t\t\tStepSquareMove:=StepSquareMove+1;\n\t\t\t\tSent:=0;\n\t\t\t\tBuffered:=0;\n\t\t\tEND_IF \n\t\t\t\n\t\t//If not Ready, return to Step 0\t\n\t\tELSE\n\t\t\t//Log when the robot stopped\n\t\t\tIF StepSquareMove > 0 THEN\n\t\t\t\tLastStep:=StepSquareMove;\n\t\t\tEND_IF\n\t\t\tStepSquareMove:=0;\n\t\tEND_IF\t\t\nElse\n\tStepSquareMove:=0;\n\tgvl.Meca500_1.Outputs.RobotControl.ResetError:=TRUE;\n\tIF GVL.Meca500_1.Inputs.Status.RobotStatus.Activated THEN \n\t\tGVL.Meca500_1.Outputs.RobotControl.Activate := FALSE;\n\t\tGVL.Meca500_1.Outputs.RobotControl.Deactivate := true;\n\tend_if;\nEND_IF","LineInfoPersistence":"(string)5af3cd89-6c20-4992-a2b0-56fc82065cff_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)PROGRAM PLC_PRG\nVAR\n\t//Demo without function block control\n\tSequenceStep:INT;\n\tStartSequence:BOOL;\n\t\n\t//demo with function block control \n\tTestSquareMove:BOOL;\n\tStepSquareMove:INT;\n\tLastStep:INT;\n\tSent:BOOL;\n\tBuffered:BOOL;\n\tError:BOOL;\n\t\n\t//Function Block instances\n\tMoveJoints:MoveJoints;\n\tSetCheckpoint:SetCheckpoint;\n\tMovePose:Movepose;\n\tMovelin:MoveLinRelTrf;\n\tSetCartLinVel:SetCartLinVel;\n\t\n\t//Positions for sequence\n\tZeroJointsValues:ARRAY[0..5]OF REAL := [0,0,0,0,0,0];\n\tMovePoseValues:ARRAY[0..5]OF REAL := [100, 0, 200, 0, 180, 0];\n\tMoveLinValues1:ARRAY[0..5]OF REAL := [50, 0, 0, 0, 0, 0];\n\tMoveLinValues2:ARRAY[0..5]OF REAL := [0, 50, 0, 0, 0, 0];\n\tMoveLinValues3:ARRAY[0..5]OF REAL := [-50 ,0, 0, 0, 0, 0];\n\tMoveLinValues4:ARRAY[0..5]OF REAL := [0 ,-50, 0, 0, 0, 0];\n//\tCalculateWRF1: CalculateWRF;\n\tresult: array[0..5] of real;\n\tpoint1: array[0..2] of real := [50,25,0];\n\tpoint2: array[0..2] of real := [175,25,10];\n\tpoint3: array[0..2] of real := [150,35,25];\nEND_VAR","LineInfoPersistence":"(string)5af3cd89-6c20-4992-a2b0-56fc82065cff_Decl_LineIds"}}}},"UniqueIdGenerator":"(string)290","POULevel":{"@Type":"8e575c5b:Enum","@Value":"Standard"},"ChildObjectGuids":{"@Type":"ArrayList:IList","@Value":[]},"AddAttributeSubsequent":"(bool)False"}},"TypeInfos":{"0db3d7bb":"{0db3d7bb-cde0-4416-9a7b-ce49a0124323}","3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","6f9dac99":"{6f9dac99-8de1-4efc-8465-68ac443b7d08}","8e575c5b":"{8e575c5b-1d37-49c6-941b-5c0ec7874787}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","ArrayList":"System.Collections.ArrayList","bool":"System.Boolean","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","string":"System.String"}}},"FormatVersion":"1.0"}